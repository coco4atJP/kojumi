PORT=8080
NODE_ENV=development

# Local development only. Use a strong secret in production.
MASTER_API_KEY=replace-with-local-dev-master-key

# Stores issued participant keys. Do not commit the generated file.
API_KEYS_FILE=data/api_keys.json

# Required for production evaluation submission.
KOJUMI_EVAL_VERIFY_SECRET=replace-with-local-dev-eval-secret

# Comma-separated browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Self-serve trial keys are disabled in production unless explicitly enabled
# with external abuse protection.
KOJUMI_TRIAL_SELF_SERVE_ENABLED=false
# KOJUMI_TRIAL_ABUSE_PROTECTION=turnstile
# KOJUMI_TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
